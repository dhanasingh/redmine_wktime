<% 
  # Pre-calculate survey structure for hierarchical rendering
  all_questions = @survey.wk_survey_questions.includes(:wk_survey_choices)
  choice_link_map = {}
  all_questions.collect(&:wk_survey_choices).flatten.each do |c|
    choice_link_map[c.id] = c.follow_up_question_id if c.follow_up_question_id.present?
  end

  followup_question_ids = Set.new
  all_questions.each do |q|
    q.wk_survey_choices.each do |c|
      followup_question_ids.add(c.follow_up_question_id) if c.follow_up_question_id.present?
    end
  end

  # Helper to check if a question or any descendant supports trending charts
  has_trend_chart_recursive = lambda do |q|
    return true if validateTrendingChart(q.survey_id, q.id)
    q.wk_survey_choices.any? do |c|
      fu_id = choice_link_map[c.id]
      fu_id.present? && @all_questions_map[fu_id] && has_trend_chart_recursive.call(@all_questions_map[fu_id])
    end
  end

  render_survey_result_item = lambda do |entry, depth, parent_index = "", qualifying_response_ids = nil, triggering_choice_id = nil|
    if params[:groupName] == 'trendChart'
      return unless has_trend_chart_recursive.call(entry)
    end
%>
    <div style="padding-left: <%= depth * 20 %>px; margin-bottom: 20px;">
      <%
        path_id = parent_index.to_s.gsub('.', '_').chomp('_')
      %>
      <% if ['TB', 'MTB'].include?(entry.question_type) %>
        <table width="100%">
          <tr>
            <th align="left" style="white-space: nowrap">
              <b><%= parent_index %></b>&nbsp;<%= entry.name %>
            </th>
          </tr>
          <% @survey_txt_answers.each do |ans_entry| %>
            <% ans_qid = ans_entry.respond_to?(:question_id) ? ans_entry.question_id : ans_entry[:question_id]
               ans_rid = ans_entry.respond_to?(:response_id) ? ans_entry.response_id : ans_entry[:response_id]
               ans_tid = ans_entry.respond_to?(:trigger_choice_id) ? ans_entry.trigger_choice_id : ans_entry[:trigger_choice_id]
            %>
            <% next unless entry.id == ans_qid.to_i %>
            <% if qualifying_response_ids
                 next unless qualifying_response_ids.include?(ans_rid.to_i)
               end %>
            <% if triggering_choice_id.present?
                 next unless ans_tid.to_i == triggering_choice_id.to_i
               else
                 next if ans_tid.present?
               end %>
              <tr><td style="padding-left: 50px;"><%= ans_entry.respond_to?(:choice_text) ? ans_entry.choice_text : ans_entry[:choice_text] %></td></tr>
          <% end %>
        </table>
      <% else %>
        <table class="odd-even" width="100%">
          <tr>
            <th align="left">
              <b><%= parent_index %></b>&nbsp;<%= entry.name %>
            </th>
          </tr>
          <tr>
            <td><%= render :partial => 'graph', :locals => { :entry => entry, :graph_id_suffix => path_id, :parent_choice_id => triggering_choice_id } if (validateTrendingChart(entry.survey_id, entry.id) || params[:groupName] != 'trendChart') %></td>
            <th style="width: 50%; font-size: 96px; text-align: center" id="avgScore_<%= entry.id %>_<%= path_id %>"></th>
          </tr>
        </table>
      <% end %>

      <%# Recursively render follow-ups linked to choices of this question — deduplicate shared follow-ups %>
      <%
        followup_groups_html = {}
        entry.wk_survey_choices.each_with_index do |choice_entry, c_idx|
          followup_id = choice_link_map[choice_entry.id]
          next unless followup_id.present? && @all_questions_map[followup_id]
          followup_groups_html[followup_id] ||= { first_c_idx: c_idx, choices: [] }
          followup_groups_html[followup_id][:choices] << { choice: choice_entry, c_idx: c_idx }
        end
      %>
      <% followup_groups_html.each do |followup_id, group_info| %>
        <%
          cur_trigger = triggering_choice_id.presence ? triggering_choice_id.to_i : nil
        %>
        <% if group_info[:choices].size == 1 %>
          <%
            choice_entry = group_info[:choices].first[:choice]
            c_idx        = group_info[:choices].first[:c_idx]
            via_selection_ids    = @responses_by_selection[[entry.id, cur_trigger, choice_entry.id]] || Set.new
            child_qualifying_ids = qualifying_response_ids ? (qualifying_response_ids & via_selection_ids) : via_selection_ids
          %>
          <% render_survey_result_item.call(@all_questions_map[followup_id], depth + 1, "#{parent_index.chomp('.').presence || ''}.#{c_idx + 1}", child_qualifying_ids, choice_entry.id) %>
        <% else %>
          <%
            combined_ids = group_info[:choices].inject(Set.new) do |acc, ch_info|
              via_ids = @responses_by_selection[[entry.id, cur_trigger, ch_info[:choice].id]] || Set.new
              acc | via_ids
            end
            child_qualifying_ids = qualifying_response_ids ? (qualifying_response_ids & combined_ids) : combined_ids
            first_c_idx = group_info[:first_c_idx]
          %>
          <% render_survey_result_item.call(@all_questions_map[followup_id], depth + 1, "#{parent_index.chomp('.').presence || ''}.#{first_c_idx + 1}", child_qualifying_ids, nil) %>
        <% end %>
      <% end %>
    </div>
<%
  end
%>

<% if action_name == 'print_survey_result' && @survey.recur %>
  <table>
    <tr>
      <th style="text-align: left"><%= l(:label_clos_responses) %></th>
      <td><%= params[:groupName].present? ? params[:groupName] : (params[:groupName].blank? && @survey_perm) ? "" : getResponseGroup.last %></td>
    </tr>
    <% if  params[:groupName].present? && @groupClosedDate.present? %>
      <tr>
        <th style="text-align: left"><%= l(:label_closed_date) %></th>
        <td><%= @groupClosedDate&.to_date %></td>
      </tr>
    <% end %>
  </table>
<% end %>

<% 
  group_counter = 0
  ungrouped_q_counter = 0
  @survey_grouped_questions.each do |group, group_questions| 
    if params[:groupName] == 'trendChart'
      any_trend_chart = group_questions.any? { |q| has_trend_chart_recursive.call(q) }
      next unless any_trend_chart
    end
%>
  <fieldset class="box tabular">
    <% if group.present? && group.name.present? %>
      <h3 style="padding-bottom: 1px;"><%= group.name %></h3>
      <% group_counter += 1 %>
    <% end %>

    <% 
        top_level_questions = group_questions.select { |q| !followup_question_ids.include?(q.id) }
    %>

    <% if group.present? && group.name.present? %>
      <%
        q_counter = 0
      %>
      <% top_level_questions.each do |entry| %>
         <% q_counter += 1 %>
         <% parent_index = "#{group_counter}.#{q_counter}." %>
         <% render_survey_result_item.call(entry, 0, parent_index) %>
      <% end %>
    <% else %>
      <% top_level_questions.each do |entry| %>
        <% ungrouped_q_counter += 1 %>
        <% parent_index = "#{ungrouped_q_counter}." %>
        <% render_survey_result_item.call(entry, 0, parent_index) %>
      <% end %>
    <% end %>
  </fieldset>
<% end %>