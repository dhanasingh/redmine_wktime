<%= stylesheet_link_tag 'payment_portal', :plugin => "redmine_wktime" %>

<div class="pp-wrapper">
  <div class="pp-card pp-card-sm">
    <!-- Header -->
    <div class="pp-header-w">
      <div class="pp-header-w-icon">
        <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      </div>
      <h2><%= l(:label_public_payment) %></h2>
      <p class="pp-header-w-sub"><%= l(:label_enter_invoice_details) %></p>
    </div>

    <!-- Step Indicator -->
    <div class="pp-steps">
      <div class="pp-step active">
        <span class="pp-step-dot">1</span> <%= l(:label_step_details) %>
      </div>
      <span class="pp-step-line"></span>
      <div class="pp-step">
        <span class="pp-step-dot">2</span> <%= l(:label_step_verify) %>
      </div>
      <span class="pp-step-line"></span>
      <div class="pp-step">
        <span class="pp-step-dot">3</span> <%= l(:label_step_pay) %>
      </div>
    </div>

    <!-- Body -->
    <div class="pp-body">
      <%= form_tag payment_send_code_path, method: :post do %>

        <!-- Invoice Number Field -->
        <div class="pp-field">
          <label for="invoice_number">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            <%= l(:label_invoice_number) %>
          </label>
          <%= text_field_tag 'invoice_number', @invoice_number, required: true, class: 'pp-input', autofocus: true %>
        </div>

        <!-- Invoice Date Field -->
        <div class="pp-field">
          <label for="invoice_date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            <%= l(:label_invoice_date) %>
          </label>
          <%= date_field_tag 'invoice_date', @invoice_date, required: true, class: 'pp-input' %>
        </div>

        <!-- CAPTCHA -->
        <div class="pp-captcha">
          <div class="pp-captcha-label">
            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <%= l(:label_security_verification) %>
          </div>
          <div class="pp-captcha-row">
            <div class="pp-captcha-question" style="padding: 0; overflow: hidden; display: flex; align-items: center; justify-content: center;">
              <img src="<%= @captcha_image %>" alt="Security Question" style="max-width: 100%; height: 50px; display: block;">
            </div>
            <%= text_field_tag 'captcha_answer', nil, size: 10, required: true, autocomplete: 'off', placeholder: 'Answer' %>
          </div>
        </div>

        <!-- Submit -->
        <button type="submit" class="pp-btn"><%= l(:label_send_verification_code) %></button>
      <% end %>


    </div>
  </div>
</div>

